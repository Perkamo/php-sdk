{
  "name": "perkamo/sdk",
  "description": "Server-side PHP client for the Perkamo API.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Perkamo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Perkamo\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2",
    "ext-hash": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 php -l"
  }
}
